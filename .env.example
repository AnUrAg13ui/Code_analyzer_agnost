# ============================================================
# AI Code Analyzer Agent — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_NAME="AI Code Analyzer Agent"
APP_VERSION="1.0.0"
DEBUG=false
LOG_LEVEL=INFO

# ── FastAPI ───────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ── GitHub ────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_yourPersonalAccessTokenHere
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
GITHUB_API_BASE=https://api.github.com

# ── PostgreSQL ────────────────────────────────────────────────
USE_DATABASE=true
DATABASE_URL=postgresql://postgres:password@127.0.0.1:5434/code_analyzer
ASYNC_DATABASE_URL=postgresql+asyncpg://postgres:password@127.0.0.1:5434/code_analyzer
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── LLM Provider ─────────────────────────────────────────────
# Choose ONE: "ollama" | "vllm" | "openai"
LLM_PROVIDER=ollama

# ── Ollama (default, recommended for local use) ───────────────
# Start with:  ollama run deepseek-coder
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-coder:6.7b

# ── vLLM (when LLM_PROVIDER=vllm) ────────────────────────────
VLLM_BASE_URL=http://localhost:8000
VLLM_MODEL=deepseek-ai/deepseek-coder-6.7b-instruct

# ── OpenAI or any OpenAI-compatible API (when LLM_PROVIDER=openai) ──
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=sk-...

# ── Universal override (highest priority) ─────────────────────
# Leave both blank to use the provider settings above.
# Set both to point ALL inference at any OpenAI-compatible URL
# without touching LLM_PROVIDER.
LLM_BASE_URL=
LLM_MODEL=
LLM_API_KEY=

# ── Inference parameters ──────────────────────────────────────
LLM_TIMEOUT=4000
LLM_MAX_TOKENS=50000000000
LLM_TEMPERATURE=0.1

# ── Analysis ──────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.65
MAX_FILES_PER_PR=50
MAX_DIFF_LINES=1000
PARALLEL_AGENT_TIMEOUT=600

# ── Rules Checker ─────────────────────────────────────────
# Set to false to disable custom_rules.yaml and let the LLM use its own defaults.
APPLY_CUSTOM_RULES=true

# ── Frontend ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
ACTIVE_AGENTS = bug_detector